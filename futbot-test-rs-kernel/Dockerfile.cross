# Cross-compilation Docker image for futbot-test-rs
# Target: armv7-unknown-linux-gnueabihf (Raspberry Pi 3 Model B)
#
# Build this image once:
#   docker build -f Dockerfile.cross -t futbot-cross-arm:latest .
#
# Then cross-compile with:
#   cross build --release --target armv7-unknown-linux-gnueabihf

FROM ghcr.io/cross-rs/armv7-unknown-linux-gnueabihf:main

# Add armhf architecture for cross-compilation libraries
RUN dpkg --add-architecture armhf && \
    apt-get update && \
    apt-get install -y \
        libopencv-dev:armhf \
        libclang-dev \
        clang \
        pkg-config \
        curl \
        ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Install OnnxRuntime prebuilt ARM binary
# Used by the `ort` crate (load-dynamic feature)
ARG ORT_VERSION=1.20.1
RUN curl -fsSL \
    "https://github.com/microsoft/onnxruntime/releases/download/v${ORT_VERSION}/onnxruntime-linux-arm-${ORT_VERSION}.tgz" \
    | tar xz -C /usr/local/ --strip-components=1

# pkg-config wrapper for cross-compilation
ENV PKG_CONFIG_PATH=/usr/lib/arm-linux-gnueabihf/pkgconfig:/usr/share/pkgconfig
ENV PKG_CONFIG_ALLOW_CROSS=1
ENV ORT_DYLIB_PATH=/usr/local/lib/libonnxruntime.so
