# ============================================================
# FutbotMX v2 — Variables de entorno
# ============================================================
# Copia este archivo a .env y edita los valores.
# En producción (RPi) estas variables se pasan al ejecutar:
#   ROBOT_ID=robot1 PEER_IP=192.168.1.20 uv run src/main.py
# ============================================================

# ── Identidad del robot ──────────────────────────────────────
# "robot1" actúa como servidor WebSocket (enciéndelo primero)
# "robot2" actúa como cliente WebSocket
ROBOT_ID=robot1

# ── Red ─────────────────────────────────────────────────────
# IP del robot OPUESTO (el otro robot en la red)
PEER_IP=192.168.22.47

# Puerto WebSocket (mismo en ambos robots)
WS_PORT=8765

# ── Hardware ─────────────────────────────────────────────────
# Poner "0" para deshabilitar el sensor ultrasónico
# (útil para pruebas sin hardware conectado)
ULTRASONIC=1

# ── Módulo WebSocket ─────────────────────────────────────────
# Poner "0" para correr sin WebSocket (modo solo, siempre atacante)
# Ideal para pruebas locales en laptop sin el otro robot
WS_ENABLED=0
